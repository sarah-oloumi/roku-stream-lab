{
  "name": "roku-stream-lab",
  "version": "0.1.0",
  "description": "A local Roku BrightScript streaming app workbench powered by Apple container.",
  "private": true,
  "type": "module",
  "bin": {
    "rokulab": "./scripts/rokulab.mjs"
  },
  "scripts": {
    "build:bs": "bsc --project bsconfig.json",
    "check:bs": "bsc --project bsconfig.json --create-package false --copy-to-staging false",
    "watch:bs": "bsc --project bsconfig.json --watch",
    "doctor": "node scripts/rokulab.mjs doctor",
    "serve": "node scripts/rokulab.mjs serve",
    "package": "node scripts/rokulab.mjs package",
    "container-build": "node scripts/rokulab.mjs container-build",
    "container-run": "node scripts/rokulab.mjs container-run",
    "test": "node tests/cli.test.mjs && node tests/brightscriptRunner.test.mjs"
  },
  "devDependencies": {
    "@rokucommunity/brs": "0.47.4",
    "brighterscript": "0.72.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
